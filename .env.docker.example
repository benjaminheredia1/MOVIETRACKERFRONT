# ============================================
# Base de datos PostgreSQL
# ============================================
POSTGRES_USER=sistema
POSTGRES_PASSWORD=sistema
POSTGRES_DB=sistema

# ============================================
# Backend Go (MovieTrackerBack/.env)
# ============================================
# host=postgres        (automático vía docker-compose)
# port=5432            (automático vía docker-compose)
# user=sistema         (automático vía docker-compose)
# password=sistema     (automático vía docker-compose)
# dbname=sistema       (automático vía docker-compose)
# app_port=8080        (automático vía docker-compose)
# REDIS_HOST=redis     (automático vía docker-compose)
# REDIS_PORT=6379      (automático vía docker-compose)

# API Keys (configurar en MovieTrackerBack/.env)
# TMDB_API_KEY=""
# TMDB_BASE_URL="https://api.themoviedb.org/3"
# OPENAI_API_KEY=""
# OPENAI_MODEL="gpt-4o-mini"
